# Core
NODE_ENV="development"
DATABASE_URL="postgresql://slideleaf:slideleaf@localhost:5432/slideleaf"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="replace-with-a-long-random-secret"
SESSION_COOKIE_NAME="slideleaf_session"

# Public URLs
WEB_URL="http://localhost:3000"
API_URL="http://localhost:4000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# S3-compatible object storage
# Local Docker Compose uses MinIO with these development defaults.
S3_ENDPOINT="http://localhost:9000"
S3_PUBLIC_ENDPOINT="http://localhost:9000"
S3_REGION="auto"
S3_BUCKET="slideleaf"
S3_ACCESS_KEY_ID="minio"
S3_SECRET_ACCESS_KEY="minio123"
S3_FORCE_PATH_STYLE="true"

# AI provider routing: anthropic, gemini, deepseek, or openai
AI_PROVIDER="anthropic"
AI_MAX_TOKENS="8192"
AI_CONTEXT_MAX_CHARS="180000"

# Anthropic / Claude
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL="https://api.anthropic.com/v1"
ANTHROPIC_MODEL="claude-sonnet-4-6"
ANTHROPIC_VERSION="2023-06-01"

# Gemini OpenAI-compatible endpoint
GEMINI_API_KEY=""
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
GEMINI_MODEL="gemini-3-flash-preview"

# DeepSeek OpenAI-compatible endpoint
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-pro"

# OpenAI-compatible fallback
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4.1-mini"
