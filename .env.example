# Core
NODE_ENV="development"
DATABASE_URL=""
REDIS_URL=""
JWT_SECRET="replace-with-a-long-random-secret"
SESSION_COOKIE_NAME="slideleaf_session"
# Use "none" with HTTPS when web and API are on different production domains.
SESSION_COOKIE_SAME_SITE="lax"

# Public URLs
WEB_URL="http://localhost:3000"
API_URL="http://localhost:4000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/auth/google/callback"

# S3-compatible object storage
# Local Docker Compose uses MinIO with these development defaults.
S3_ENDPOINT="http://localhost:9000"
S3_PUBLIC_ENDPOINT="http://localhost:9000"
S3_REGION="auto"
S3_BUCKET="slideleaf"
S3_ACCESS_KEY_ID="minio"
S3_SECRET_ACCESS_KEY="minio123"
S3_FORCE_PATH_STYLE="true"

# AI provider routing. The product UI exposes DeepSeek, Gemini, Claude Sonnet, and Claude Opus.
AI_PROVIDER="deepseek"
AI_MAX_TOKENS="384000"
AI_CONTEXT_MAX_CHARS="4194304"

# Anthropic / Claude
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL="https://api.anthropic.com/v1"
ANTHROPIC_MODEL="claude-sonnet-4-6"
ANTHROPIC_SONNET_MODEL="claude-sonnet-4-6"
ANTHROPIC_OPUS_MODEL="claude-opus-4-7"
ANTHROPIC_SONNET_MAX_TOKENS="64000"
ANTHROPIC_OPUS_MAX_TOKENS="128000"
ANTHROPIC_SONNET_EFFORT="medium"
ANTHROPIC_OPUS_EFFORT="high"
ANTHROPIC_VERSION="2023-06-01"

# Gemini OpenAI-compatible endpoint
GEMINI_API_KEY=""
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
GEMINI_MODEL="gemini-3.1-flash-lite"
GEMINI_MAX_TOKENS="65536"

# DeepSeek OpenAI-compatible endpoint
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-pro"
DEEPSEEK_MAX_TOKENS="384000"

# OpenAI-compatible fallback
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4.1-mini"
